# STM32 Embedded C++ Project - .gitignore
# Keep source files, Drivers folder, and project configuration
# Exclude build artifacts, temporary files, and IDE-specific files

# ========================
# STM32CubeIDE Build Files
# ========================
# Build directories
[Dd]ebug/
[Rr]elease/
[Bb]uild/

# Compiled object files and build artifacts
*.o
*.obj
*.elf
*.bin
*.hex
*.map
*.list
*.lss
*.sym
*.tmp

# Dependencies and intermediate files
*.d
*.su
*.cyclo

# Makefiles (generated)
*.mk
makefile
objects.list
objects.mk
sources.mk

# ========================
# General C/C++ Build Files
# ========================

# Compiled Object files
*.slo
*.lo

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod
*.smod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# ========================
# STM32CubeIDE Workspace
# ========================
# Metadata and workspace files
.metadata/
.project
.cproject
.settings/
*.launch

# ========================
# VS Code Files
# ========================
# Don't ignore .vscode/ as it contains important configuration
# But ignore some user-specific files within it
.vscode/launch.json
.vscode/tasks.json
.vscode/extensions.json
.vscode/.cortex-debug.*

# ========================
# System and Editor Files
# ========================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# ========================
# Log and Temporary Files
# ========================
*.log
*.tmp
*.temp

# ========================
# Generated Documentation
# ========================
html/
latex/
doc/

# User-specific configuration
*.user
.github/copilot-instructions.md
/.vscode/c_cpp_properties.json
/.vscode/settings.json